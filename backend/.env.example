# ---- Django core ----
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.yourdomain.com,localhost,127.0.0.1

# ---- CORS / CSRF ----
# Comma-separated list of frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com

# ---- Realtime (WebSockets) ----
# Set to enable the Redis channel layer (required for multi-process/production).
# Leave unset for local single-process development (uses in-memory layer).
REDIS_URL=redis://127.0.0.1:6379/0

# ---- Database (optional; omit to use the bundled SQLite file) ----
# POSTGRES_DB=grocery
# POSTGRES_USER=grocery
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# ---- HTTPS hardening (only used when DJANGO_DEBUG=False) ----
# Set to False if TLS is terminated upstream and you don't want app-level redirects.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_HSTS_SECONDS=31536000

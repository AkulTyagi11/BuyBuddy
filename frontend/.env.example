# Full base URL of the backend REST API (including the /api suffix).
# Leave unset in local dev to use the Vite proxy (/api -> http://127.0.0.1:8000).
# Required for production web builds and for mobile (Capacitor) builds, which
# have no dev proxy.
VITE_API_BASE_URL=https://api.yourdomain.com/api

# Base URL for the WebSocket server (no trailing slash), e.g. wss://api.yourdomain.com
# Required for production and mobile builds. In local dev it is derived automatically.
VITE_WS_BASE_URL=wss://api.yourdomain.com
